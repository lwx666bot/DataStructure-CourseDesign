{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build-all-cpp",
            "command": "C:\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\Menu.cpp",
                "${workspaceFolder}\\QueueSystem.cpp",
                "-o",
                "${workspaceFolder}\\main.exe"
            ],
            "options": {
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": ["/c"]
                },
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
