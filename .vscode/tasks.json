{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build-all-cpp",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/main.cpp",
                "${workspaceFolder}/Menu/Menu.cpp",
                "${workspaceFolder}/QueueSystem/QueueSystem.cpp",
                "-o",
                "${workspaceFolder}/main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "windows": {
                "command": "C:\\mingw64\\bin\\g++.exe",
                "args": [
                    "-fdiagnostics-color=always",
                    "-g",
                    "${workspaceFolder}/main.cpp",
                    "${workspaceFolder}/Menu/Menu.cpp",
                    "${workspaceFolder}/QueueSystem/QueueSystem.cpp",
                    "-o",
                    "${workspaceFolder}/main.exe"
                ],
                "options": {
                    "shell": {
                        "executable": "C:\\Windows\\System32\\cmd.exe",
                        "args": [
                            "/c"
                        ]
                    },
                    "cwd": "${workspaceFolder}"
                }
            },
            "osx": {
                "command": "g++",
                "args": [
                    "-fdiagnostics-color=always",
                    "-g",
                    "${workspaceFolder}/main.cpp",
                    "${workspaceFolder}/Menu/Menu.cpp",
                    "${workspaceFolder}/QueueSystem/QueueSystem.cpp",
                    "-o",
                    "${workspaceFolder}/main"
                ]
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
