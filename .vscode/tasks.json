{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "prepare-build-dir",
            "command": "mkdir",
            "args": [
                "-p",
                "${workspaceFolder}/build"
            ],
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\""
                ]
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++ 生成整个项目",
            "command": "g++",
            "dependsOn": "prepare-build-dir",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17",
                "-g",
                "-I${workspaceFolder}/Main",
                "-I${workspaceFolder}/Main/Function",
                "-I${workspaceFolder}/RestaurantQueueSystem",
                "-I${workspaceFolder}/ExpressionCalculatorSystem",
                "${workspaceFolder}/Main/main.cpp",
                "${workspaceFolder}/Main/Function/Function.cpp",
                "${workspaceFolder}/Main/Menu/Menu.cpp",
                "${workspaceFolder}/RestaurantQueueSystem/QueueSystem/QueueSystem.cpp",
                "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionTree/ExpressionTree.cpp",
                "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionCalculator/ExpressionCalculator.cpp",
                "-o",
                "${workspaceFolder}/build/main.exe"
            ],
            "windows": {
                "command": "C:\\mingw64\\bin\\g++.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "使用 g++ 编译整个课程设计项目。"
        },
        {
            "type": "shell",
            "label": "build-all-cpp",
            "command": "clang++",
            "dependsOn": "prepare-build-dir",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17",
                "-g",
                "-I${workspaceFolder}/Main",
                "-I${workspaceFolder}/Main/Function",
                "-I${workspaceFolder}/RestaurantQueueSystem",
                "-I${workspaceFolder}/ExpressionCalculatorSystem",
                "${workspaceFolder}/Main/main.cpp",
                "${workspaceFolder}/Main/Function/Function.cpp",
                "${workspaceFolder}/Main/Menu/Menu.cpp",
                "${workspaceFolder}/RestaurantQueueSystem/QueueSystem/QueueSystem.cpp",
                "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionTree/ExpressionTree.cpp",
                "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionCalculator/ExpressionCalculator.cpp",
                "-o",
                "${workspaceFolder}/build/main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "windows": {
                "command": "C:\\mingw64\\bin\\g++.exe",
                "args": [
                    "-fdiagnostics-color=always",
                    "-std=c++17",
                    "-g",
                    "-I${workspaceFolder}/Main",
                    "-I${workspaceFolder}/Main/Function",
                    "-I${workspaceFolder}/RestaurantQueueSystem",
                    "-I${workspaceFolder}/ExpressionCalculatorSystem",
                    "${workspaceFolder}/Main/main.cpp",
                    "${workspaceFolder}/Main/Function/Function.cpp",
                    "${workspaceFolder}/Main/Menu/Menu.cpp",
                    "${workspaceFolder}/RestaurantQueueSystem/QueueSystem/QueueSystem.cpp",
                    "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionTree/ExpressionTree.cpp",
                    "${workspaceFolder}/ExpressionCalculatorSystem/ExpressionCalculator/ExpressionCalculator.cpp",
                    "-o",
                    "${workspaceFolder}/build/main.exe"
                ],
                "options": {
                    "shell": {
                        "executable": "C:\\Windows\\System32\\cmd.exe",
                        "args": [
                            "/c"
                        ]
                    },
                    "cwd": "${workspaceFolder}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        }
    ]
}
